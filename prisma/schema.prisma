generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                  @id @default(cuid())
  email               String                  @unique
  password            String
  name                String
  phone               String?
  avatar              String?
  role                Role                    @default(CUSTOMER)
  emailVerified       DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  address             String?
  assignedLocationId  String?
  bio                 String?
  dateOfBirth         DateTime?
  gender              String?
  nerdCoinBalance     Int                     @default(0)
  nerdCoinTier        String                  @default("BRONZE")
  isLocked            Boolean                 @default(false)
  occupation          String?
  profileCompletedAt  DateTime?
  region              String?
  school              String?
  visitPurpose        String[]
  accounts            Account[]
  bookings            Booking[]
  nerdCoinTxns        NerdCoinTransaction[]
  posts               Post[]
  registrationOrders  RegistrationOrder[]
  sessions            Session[]
  matchesAsA          StudyMatch[]            @relation("MatchUserA")
  matchesAsB          StudyMatch[]            @relation("MatchUserB")
  studyProfile        StudyProfile?
  subscriber          Subscriber?
  assignedLocation    Location?               @relation(fields: [assignedLocationId], references: [id])
  studyAvailabilities UserStudyAvailability[]
  wallet              Wallet?
  createdWalletTxns   WalletTransaction[]     @relation("WalletTransactionCreator")

  @@index([name])
  @@index([phone])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Room {
  id          String    @id @default(cuid())
  name        String
  type        RoomType
  description String?
  capacity    Int
  amenities   String[]
  image       String?
  isActive    Boolean   @default(true)
  locationId  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bookings    Booking[]
  location    Location  @relation(fields: [locationId], references: [id])
}

model Location {
  id         String      @id @default(cuid())
  name       String
  address    String
  phone      String
  mapUrl     String?
  image      String?
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  bookings   Booking[]
  rooms      Room[]
  studySlots StudySlot[]
  staff      User[]
}

model Service {
  id             String      @id @default(cuid())
  name           String
  slug           String      @unique
  type           ServiceType
  description    String?
  priceSmall     Int?
  priceLarge     Int?
  priceFirstHour Int?
  pricePerHour   Int?
  pricingTiers   Json?
  nerdCoinReward Int         @default(0)
  minDuration    Int         @default(60)
  timeStep       Int         @default(30)
  features       String[]
  icon           String?
  isActive       Boolean     @default(true)
  sortOrder      Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  image          String?
}

model Combo {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  duration    Int
  price       Int
  description String?
  features    String[]
  icon        String?
  isPopular   Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  image       String?
}

model Booking {
  id               String        @id @default(cuid())
  bookingCode      String        @unique
  userId           String?
  locationId       String
  date             DateTime      @db.Date
  startTime        String
  endTime          String
  guests           Int           @default(1)
  status           BookingStatus @default(PENDING)
  note             String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  actualAmount     Int?
  actualEndTime    DateTime?
  actualStartTime  DateTime?
  customerEmail    String?
  customerName     String
  customerPhone    String
  depositAmount    Int
  depositPaidAt    DateTime?
  depositStatus    DepositStatus @default(PENDING)
  estimatedAmount  Int
  nerdCoinIssued   Int           @default(0)
  nerdCoinIssuedAt DateTime?
  remainingAmount  Int?
  roomId           String
  source           BookingSource @default(WEBSITE)
  paymentStartedAt DateTime?
  endDate          DateTime?     @db.Date
  isRescheduled    Boolean       @default(false)
  location         Location      @relation(fields: [locationId], references: [id])
  room             Room          @relation(fields: [roomId], references: [id])
  user             User?         @relation(fields: [userId], references: [id])
  payment          Payment?

  @@index([roomId])
  @@index([locationId])
  @@index([date])
  @@index([status])
  @@index([customerPhone])
  @@index([customerName])
  @@index([customerEmail])
}

model Payment {
  id            String        @id @default(cuid())
  bookingId     String        @unique
  amount        Int
  method        PaymentMethod
  transactionId String?
  gatewayData   Json?
  status        PaymentStatus @default(PENDING)
  paidAt        DateTime?
  refundedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  booking       Booking       @relation(fields: [bookingId], references: [id])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id            String     @id @default(cuid())
  title         String
  slug          String     @unique
  type          PostType   @default(NEWS)
  excerpt       String?
  content       String
  thumbnail     String?
  images        String[]
  authorId      String
  status        PostStatus @default(DRAFT)
  publishedAt   DateTime?
  eventDate     DateTime?
  eventTime     String?
  eventLocation String?
  featured      Boolean    @default(false)
  viewCount     Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  author        User       @relation(fields: [authorId], references: [id])

  @@index([type])
  @@index([status])
  @@index([publishedAt])
  @@index([authorId])
}

model NerdCoinTransaction {
  id          String          @id @default(cuid())
  userId      String
  amount      Int
  type        NerdCoinTxnType
  description String?
  bookingId   String?
  createdAt   DateTime        @default(now())
  user        User            @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  bookingId String?
  createdAt DateTime         @default(now())

  @@index([isRead])
  @@index([createdAt])
  @@index([type])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  userName   String
  action     String
  resource   String
  resourceId String?
  details    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  subject   String
  content   String
  variables String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatConversation {
  id             String        @id @default(cuid())
  guestName      String?
  guestEmail     String?
  guestPhone     String?
  guestSessionId String?
  userId         String?
  assignedToId   String?
  status         ChatStatus    @default(OPEN)
  source         String?
  subject        String?
  lastMessageAt  DateTime?
  unreadCount    Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  closedAt       DateTime?
  messages       ChatMessage[]

  @@index([status])
  @@index([assignedToId])
  @@index([userId])
  @@index([guestSessionId])
  @@index([lastMessageAt])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  content        String
  attachments    String[]
  senderType     SenderType
  senderId       String?
  senderName     String?
  isRead         Boolean          @default(false)
  createdAt      DateTime         @default(now())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@index([senderType])
}

model Job {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  description  String
  location     String
  workShift    String
  requirements String
  benefits     String
  isActive     Boolean       @default(true)
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]

  @@index([isActive])
  @@index([sortOrder])
}

model Application {
  id                String            @id @default(cuid())
  jobId             String
  name              String
  phone             String
  email             String?
  preferredLocation String
  cvUrl             String?
  availability      String?
  status            ApplicationStatus @default(NEW)
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  job               Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([status])
  @@index([createdAt])
}

model Feedback {
  id        String         @id @default(cuid())
  userId    String?
  name      String
  email     String?
  phone     String?
  type      FeedbackType   @default(OTHER)
  subject   String?
  content   String
  images    String[]
  status    FeedbackStatus @default(PENDING)
  adminNote String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model StudyProfile {
  id                String             @id @default(cuid())
  userId            String             @unique
  seeking           StudySeeking[]
  dateLevel         StudyDateLevel?
  preferredFormat   StudyFormat?
  workMode          StudyWorkMode?
  interactionLevel  InteractionLevel?
  environment       StudyEnvironment?
  introExtro        IntroExtro?
  primaryFocus      String?
  supportPreference SupportPreference?
  ageRangeMin       Int?
  ageRangeMax       Int?
  shareContact      Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudySlot {
  id             String                  @id @default(cuid())
  locationId     String
  dayOfWeek      Int
  startTime      String
  endTime        String
  capacity       Int                     @default(20)
  isActive       Boolean                 @default(true)
  createdAt      DateTime                @default(now())
  matches        StudyMatch[]
  location       Location                @relation(fields: [locationId], references: [id])
  availabilities UserStudyAvailability[]

  @@index([locationId])
  @@index([dayOfWeek])
}

model UserStudyAvailability {
  id        String             @id @default(cuid())
  userId    String
  slotId    String
  weekStart DateTime           @db.Date
  status    AvailabilityStatus @default(OPEN)
  createdAt DateTime           @default(now())
  slot      StudySlot          @relation(fields: [slotId], references: [id], onDelete: Cascade)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slotId, weekStart])
  @@index([userId])
  @@index([slotId])
}

model StudyMatch {
  id          String      @id @default(cuid())
  slotId      String
  date        DateTime    @db.Date
  userAId     String
  userBId     String
  status      MatchStatus @default(PENDING_CONFIRMATION)
  confirmA    Boolean     @default(false)
  confirmB    Boolean     @default(false)
  isCompleted Boolean     @default(false)
  feedbackA   Json?
  feedbackB   Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  slot        StudySlot   @relation(fields: [slotId], references: [id])
  userA       User        @relation("MatchUserA", fields: [userAId], references: [id])
  userB       User        @relation("MatchUserB", fields: [userBId], references: [id])

  @@index([slotId])
  @@index([date])
  @@index([status])
}

model Subscriber {
  id                 String                @id @default(cuid())
  fullName           String
  phone              String                @unique
  email              String?
  photoUrl           String?
  cardNo             String?               @unique
  mytimeEmpId        String?               @unique
  branchPrimary      String?
  status             SubscriberStatus      @default(ACTIVE)
  notes              String?
  userId             String?               @unique
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  loyaltyTier        String                @default("BRONZE")
  outstandingBalance Int                   @default(0)
  walletBalance      Int                   @default(0)
  walletCode         String?
  dailyUsages        DailyUsage[]
  quickCalls         QuickCall[]
  registrationOrders RegistrationOrder[]   @relation("SubscriberOrders")
  user               User?                 @relation(fields: [userId], references: [id])
  subscriptions      Subscription[]
  sessions           SubscriptionSession[]
  transactions       Transaction[]

  @@index([phone])
  @@index([cardNo])
  @@index([walletCode])
  @@index([status])
}

model Wallet {
  id               String              @id @default(cuid())
  userId           String              @unique
  walletCode       String              @unique
  balance          Int                 @default(0)
  status           WalletStatus        @default(ACTIVE)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  bankTransactions BankTransaction[]   @relation("BankMatchedWallet")
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     WalletTransaction[]

  @@index([walletCode])
  @@index([status])
  @@index([createdAt])
}

model WalletTransaction {
  id                    String                  @id @default(cuid())
  walletId              String
  type                  WalletTransactionType
  amount                Int
  balanceBefore         Int
  balanceAfter          Int
  status                WalletTransactionStatus @default(COMPLETED)
  source                WalletTransactionSource @default(SYSTEM)
  referenceType         String?
  referenceId           String?
  externalTransactionId String?                 @unique
  description           String?
  note                  String?
  createdById           String?
  rawPayload            Json?
  createdAt             DateTime                @default(now())
  bankTransaction       BankTransaction?        @relation("MatchedWalletTransaction")
  createdBy             User?                   @relation("WalletTransactionCreator", fields: [createdById], references: [id])
  wallet                Wallet                  @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([type])
  @@index([status])
  @@index([source])
  @@index([referenceType, referenceId])
  @@index([createdAt])
}

model BankTransaction {
  id                    String                @id @default(cuid())
  externalTransactionId String                @unique
  bankAccount           String?
  amount                Int
  transType             String?
  content               String?
  transactionTime       DateTime?
  status                BankTransactionStatus @default(PENDING)
  matchedWalletId       String?
  matchedTransactionId  String?               @unique
  rawPayload            Json?
  note                  String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  matchedTransaction    WalletTransaction?    @relation("MatchedWalletTransaction", fields: [matchedTransactionId], references: [id])
  matchedWallet         Wallet?               @relation("BankMatchedWallet", fields: [matchedWalletId], references: [id])

  @@index([status])
  @@index([matchedWalletId])
  @@index([transactionTime])
  @@index([createdAt])
}

model Subscription {
  id                 String                @id @default(cuid())
  subscriberId       String
  planType           PlanType
  pricePaid          Int
  status             SubscriptionStatus    @default(PENDING_ACTIVATION)
  purchasedAt        DateTime              @default(now())
  activationDate     DateTime?
  startDate          DateTime?             @db.Date
  endDate            DateTime?             @db.Date
  activationDeadline DateTime?
  totalHoursMin      Int?
  usedHoursMin       Int                   @default(0)
  carriedHoursMin    Int                   @default(0)
  dailyLimitMin      Int?
  paymentMethod      String?
  paymentRef         String?
  cardAssigned       String?
  cardAssignedAt     DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  dailyUsages        DailyUsage[]
  registrationOrders RegistrationOrder[]   @relation("SubscriptionOrders")
  subscriber         Subscriber            @relation(fields: [subscriberId], references: [id])
  sessions           SubscriptionSession[]

  @@index([subscriberId])
  @@index([status])
  @@index([endDate])
}

model SubscriptionSession {
  id             String        @id @default(cuid())
  subscriberId   String
  subscriptionId String?
  branch         String
  checkInTime    DateTime
  checkOutTime   DateTime?
  durationMin    Int?
  isFirstCheckin Boolean       @default(false)
  source         String        @default("card")
  mytimeRaw      Json?
  staffVerified  Boolean       @default(false)
  notes          String?
  createdAt      DateTime      @default(now())
  amountCharged  Int           @default(0)
  overageMin     Int           @default(0)
  status         SessionStatus @default(ACTIVE)
  subscriber     Subscriber    @relation(fields: [subscriberId], references: [id])
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([subscriberId])
  @@index([subscriptionId])
  @@index([checkInTime])
}

model DailyUsage {
  id             String       @id @default(cuid())
  subscriberId   String
  subscriptionId String
  usageDate      DateTime     @db.Date
  totalMin       Int          @default(0)
  subscriber     Subscriber   @relation(fields: [subscriberId], references: [id])
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

  @@unique([subscriberId, usageDate])
  @@index([subscriptionId])
}

model RegistrationOrder {
  id             String        @id @default(cuid())
  orderCode      String        @unique
  fullName       String
  phone          String
  email          String?
  branchPrimary  String
  planType       PlanType
  selfieUrl      String
  orderStatus    OrderStatus   @default(PENDING_PAYMENT)
  paymentMethod  String?
  paymentRef     String?
  paidAt         DateTime?
  amount         Int
  assignedCardNo String?
  assignedBy     String?
  assignedAt     DateTime?
  subscriberId   String?
  subscriptionId String?
  createdAt      DateTime      @default(now())
  expiresAt      DateTime?
  userId         String?
  subscriber     Subscriber?   @relation("SubscriberOrders", fields: [subscriberId], references: [id])
  subscription   Subscription? @relation("SubscriptionOrders", fields: [subscriptionId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])

  @@index([orderStatus])
  @@index([phone])
  @@index([createdAt])
  @@index([userId])
}

model SubscriptionAuditLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String?
  entityId    String?
  performedBy String?
  details     Json?
  createdAt   DateTime @default(now())

  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Transaction {
  id            String          @id @default(cuid())
  subscriberId  String
  type          TransactionType
  amount        Int
  balanceBefore Int
  balanceAfter  Int
  reference     String?
  description   String?
  createdAt     DateTime        @default(now())
  subscriber    Subscriber      @relation(fields: [subscriberId], references: [id])

  @@index([subscriberId])
  @@index([type])
  @@index([createdAt])
}

model QuickCall {
  id           String     @id @default(cuid())
  subscriberId String
  branch       String
  room         String?
  startTime    DateTime   @default(now())
  endTime      DateTime?
  durationMin  Int?
  loggedBy     String?
  createdAt    DateTime   @default(now())
  subscriber   Subscriber @relation(fields: [subscriberId], references: [id])

  @@index([subscriberId])
  @@index([startTime])
}

enum Role {
  ADMIN
  STAFF
  CUSTOMER
  MANAGER
  CONTENT_EDITOR
}

enum RoomType {
  MEETING_LONG
  MEETING_ROUND
  POD_MONO
  POD_MULTI
}

enum ServiceType {
  MEETING
  POD_MONO
  POD_MULTI
}

enum BookingSource {
  WEBSITE
  ONSITE
  PHONE
  ZALO
}

enum DepositStatus {
  PENDING
  PAID_ONLINE
  PAID_CASH
  WAIVED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentMethod {
  CASH
  VNPAY
  MOMO
  ZALOPAY
  BANK_TRANSFER
  WALLET
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum PostType {
  NEWS
  EVENT
  PAGE
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum NerdCoinTxnType {
  EARN
  REDEEM
  BONUS
  EXPIRED
  ADJUSTMENT
}

enum NotificationType {
  BOOKING_NEW
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  PAYMENT_RECEIVED
  CHECKIN
  CHECKOUT
  SYSTEM
}

enum ChatStatus {
  OPEN
  ASSIGNED
  RESOLVED
  CLOSED
}

enum SenderType {
  GUEST
  STAFF
  SYSTEM
}

enum ApplicationStatus {
  NEW
  REVIEWING
  INTERVIEWED
  ACCEPTED
  REJECTED
}

enum FeedbackStatus {
  PENDING
  REVIEWED
  RESOLVED
  IGNORED
}

enum FeedbackType {
  SERVICE_QUALITY
  FACILITIES
  STAFF_ATTITUDE
  SUGGESTION
  OTHER
}

enum StudySeeking {
  STUDY_BUDDY
  WORK_BUDDY
  OPEN_TO_DATE
}

enum StudyDateLevel {
  FOCUS_ONLY
  BALANCED
  DATE_HEAVY
}

enum StudyFormat {
  ONE_ON_ONE
  GROUP
}

enum StudyWorkMode {
  SILENT
  POMODORO
  CASUAL_CHAT
}

enum InteractionLevel {
  LOW
  MEDIUM
  HIGH
}

enum StudyEnvironment {
  QUIET
  LIGHT_MUSIC
  DONT_CARE
}

enum IntroExtro {
  INTROVERT
  AMBIVERT
  EXTROVERT
}

enum SupportPreference {
  JUST_PRESENCE
  QUICK_REVIEW
  SKILL_SWAP
}

enum AvailabilityStatus {
  OPEN
  MATCHED
  CANCELLED
}

enum MatchStatus {
  PENDING_CONFIRMATION
  PARTIAL_CONFIRMED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum SubscriberStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum PlanType {
  WEEKLY_LIMITED
  MONTHLY_LIMITED
  MONTHLY_UNLIMITED
}

enum SubscriptionStatus {
  PENDING_PAYMENT
  PENDING_ACTIVATION
  ACTIVE
  EXPIRED
  CANCELLED
  RENEWED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  CARD_ASSIGNED
  ACTIVATED
  CANCELLED
  ORDER_EXPIRED
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  FORCE_CLOSED
}

enum TransactionType {
  TOPUP
  SESSION_CHARGE
  OVERAGE_CHARGE
  SUBSCRIPTION_PURCHASE
  REFUND
  OVERAGE_PAYMENT
  BOOKING_PAYMENT
}

enum WalletStatus {
  ACTIVE
  LOCKED
}

enum WalletTransactionType {
  TOPUP
  DEBIT
  ADJUSTMENT
  REFUND
  BOOKING_PAYMENT
  SUBSCRIPTION_PURCHASE
  SESSION_CHARGE
  OVERAGE_CHARGE
  OVERAGE_PAYMENT
}

enum WalletTransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum WalletTransactionSource {
  SYSTEM
  VIETQR
  MANUAL_ADMIN
  BOOKING
  SUBSCRIPTION
